# ── PerfHub Configuration ────────────────────────────────────────────────────
# Copier ce fichier en .env et adapter les valeurs

# PostgreSQL
POSTGRES_DB=perfhub
POSTGRES_USER=perfhub
POSTGRES_PASSWORD=perfhub_secret_change_me

# JWT — OBLIGATOIRE en production : changer ce secret !
JWT_SECRET=perfhub-super-secret-key-change-in-production-2024-minimum-32-chars

# Ports
FRONTEND_PORT=80

# Git
GIT_SSL_VERIFY=false
GIT_TIMEOUT=120
